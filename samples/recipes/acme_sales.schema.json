{
  "project": "acme",
  "title": "Acme Sales",
  "description": "Warehouse of Acme's e-commerce sales data: customers, orders, order items, and products.",
  "console_url": "https://console.cloud.google.com/bigquery?project=acme",
  "datasets": [
    {
      "id": "sales",
      "description": "Transactional sales facts and the dimensions they reference.",
      "tables": [
        {
          "name": "customers",
          "description": "One row per registered Acme customer.",
          "num_rows": 184203,
          "columns": [
            {"name": "customer_id", "type": "STRING", "mode": "REQUIRED", "description": "Globally unique customer identifier (primary key)."},
            {"name": "email", "type": "STRING", "mode": "NULLABLE", "description": "Account email address."},
            {"name": "country", "type": "STRING", "mode": "NULLABLE", "description": "ISO-3166 country code of the billing address."},
            {"name": "created_at", "type": "TIMESTAMP", "mode": "REQUIRED", "description": "When the account was created."}
          ]
        },
        {
          "name": "products",
          "description": "Catalog of sellable products.",
          "num_rows": 5231,
          "columns": [
            {"name": "product_id", "type": "STRING", "mode": "REQUIRED", "description": "Primary key for the product."},
            {"name": "name", "type": "STRING", "mode": "REQUIRED", "description": "Display name."},
            {"name": "category", "type": "STRING", "mode": "NULLABLE", "description": "Merchandising category."},
            {"name": "unit_price", "type": "NUMERIC", "mode": "REQUIRED", "description": "List price in USD."}
          ]
        },
        {
          "name": "orders",
          "description": "One row per completed customer order.",
          "num_rows": 992104,
          "columns": [
            {"name": "order_id", "type": "STRING", "mode": "REQUIRED", "description": "Primary key for the order."},
            {"name": "customer_id", "type": "STRING", "mode": "REQUIRED", "description": "The customer who placed the order (FK to customers)."},
            {"name": "status", "type": "STRING", "mode": "REQUIRED", "description": "Order lifecycle status."},
            {"name": "total_amount", "type": "NUMERIC", "mode": "REQUIRED", "description": "Order total in USD."},
            {"name": "ordered_at", "type": "TIMESTAMP", "mode": "REQUIRED", "description": "When the order was placed."}
          ]
        },
        {
          "name": "order_items",
          "description": "Line items belonging to an order; the fact grain of the warehouse.",
          "num_rows": 4381992,
          "columns": [
            {"name": "order_item_id", "type": "STRING", "mode": "REQUIRED", "description": "Primary key for the line item."},
            {"name": "order_id", "type": "STRING", "mode": "REQUIRED", "description": "Parent order (FK to orders)."},
            {"name": "product_id", "type": "STRING", "mode": "REQUIRED", "description": "Product sold (FK to products)."},
            {"name": "quantity", "type": "INT64", "mode": "REQUIRED", "description": "Units purchased."},
            {"name": "line_total", "type": "NUMERIC", "mode": "REQUIRED", "description": "quantity * unit_price at time of sale."}
          ]
        }
      ]
    },
    {
      "id": "marketing",
      "description": "Marketing attribution linking campaigns to customers.",
      "tables": [
        {
          "name": "campaigns",
          "description": "Marketing campaigns Acme has run.",
          "num_rows": 340,
          "columns": [
            {"name": "campaign_id", "type": "STRING", "mode": "REQUIRED", "description": "Primary key."},
            {"name": "channel", "type": "STRING", "mode": "REQUIRED", "description": "Acquisition channel (email, paid, social)."},
            {"name": "started_at", "type": "DATE", "mode": "REQUIRED", "description": "Launch date."}
          ]
        },
        {
          "name": "touchpoints",
          "description": "Customer interactions attributed to a campaign.",
          "num_rows": 2100553,
          "columns": [
            {"name": "touchpoint_id", "type": "STRING", "mode": "REQUIRED", "description": "Primary key."},
            {"name": "customer_id", "type": "STRING", "mode": "REQUIRED", "description": "Customer touched (FK to customers)."},
            {"name": "campaign_id", "type": "STRING", "mode": "REQUIRED", "description": "Campaign responsible (FK to campaigns)."},
            {"name": "occurred_at", "type": "TIMESTAMP", "mode": "REQUIRED", "description": "When the touch happened."}
          ]
        }
      ]
    }
  ]
}
